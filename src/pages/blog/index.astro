---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import Tag from '../../components/Tag.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Collect unique tags
const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---

<Base title="Bài viết" description="Tất cả bài viết về kiến trúc phần mềm, tư duy hệ thống và những bài học thực tế.">
  <div class="max-w-content mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <header class="mb-10">
      <h1 class="font-serif text-3xl sm:text-4xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50 mb-3">
        Bài viết
      </h1>
      <p class="text-zinc-500 dark:text-zinc-400">
        {posts.length} bài · kiến trúc, hệ thống, thực tế
      </p>
    </header>

    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-10 pb-10 border-b border-zinc-200 dark:border-zinc-800">
        {allTags.map(tag => <Tag name={tag} />)}
      </div>
    )}

    {posts.length > 0 ? (
      <div class="space-y-4">
        {posts.map(post => <PostCard post={post} />)}
      </div>
    ) : (
      <p class="text-zinc-500 dark:text-zinc-400 text-center py-20">
        Chưa có bài viết nào.
      </p>
    )}
  </div>
</Base>
